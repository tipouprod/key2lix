# Copy to .env and set your values. Do not commit .env.

# ===== Server =====
PORT=3000

# ===== P17: قاعدة البيانات — sqlite (افتراضي) أو postgres =====
# DB_DRIVER=sqlite
# DB_DRIVER=postgres
# عند postgres أضف: DATABASE_URL=postgresql://user:pass@host:5432/dbname
# اسم ملف SQLite (افتراضي key2lix.db). إذا كانت بياناتك القديمة في keylix.db فضع:
# DB_FILENAME=keylix.db

# ===== ngrok (للمشاركة المحلية عبر الإنترنت — اختياري) =====
# احصل على التوكن من https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken
# نطاق ثابت (باقة مدفوعة): احجزه من لوحة ngrok ثم ضعه هنا، مثال: key2lix.ngrok-free.app
# NGROK_DOMAIN=key2lix.ngrok-free.app
# Host to bind (optional; default 0.0.0.0)
# HOST=0.0.0.0
NODE_ENV=development
# Use pre-built client from dist/ when 1 (optional)
# USE_BUILD=0

# ===== Base URL & Session =====
# Full site URL for sitemap and emails
BASE_URL=https://key2lix.com
SITE_URL=https://key2lix.com
# مطلوب في الإنتاج: سري قوي عشوائي (32+ حرفاً) لتوقيع جلسات الأدمن والعميل والبائع
SESSION_SECRET=your-strong-random-secret-at-least-32-chars
# S3: تسجيل خروج تلقائي بعد عدم النشاط (دقائق). 0 = تعطيل. في الإنتاج افتراضي 60
# SESSION_INACTIVITY_MINUTES=60

# ===== Admin =====
ADMIN_USER=admin
ADMIN_PASS=your-secure-password

# ===== Commission (multi-vendor, DZD) =====
# Threshold: below this price use rate_below, from this price use rate_above
COMMISSION_THRESHOLD=4000
COMMISSION_RATE_BELOW=0.10
COMMISSION_RATE_ABOVE=0.05

# ===== ضمان التسليم أو الاسترداد (ساعات — راجع docs/FUTURE-INNOVATIVE-PLANS.md) =====
# DELIVERY_GUARANTEE_HOURS=24

# ===== تجربة أول طلب (كود خصم للطلبات الأولى — يعرض في الرئيسية للمستخدمين الجدد) =====
# FIRST_ORDER_COUPON_CODE=FIRST10

# ===== عرض العملات (للعرض فقط — راجع docs/MULTI-CURRENCY-PLAN.md) =====
# عدد الدنانير مقابل 1 USD و 1 EUR؛ تُستخدم عند عدم ضبطها من لوحة الأدمن
# CURRENCY_RATE_USD=270
# CURRENCY_RATE_EUR=300

# ===== Rate limit (S2) — لكل IP خلال 15 دقيقة =====
# RATE_LIMIT_API_MAX=500
# RATE_LIMIT_ORDER_POST_MAX=15   (طلبات POST /api/order أقسى)
# RATE_LIMIT_ADMIN_MAX=2000      (واجهات الأدمن أوسع)

# ===== Request body size limit (optional; default 500kb) =====
# BODY_LIMIT=500kb

# ===== Logging =====
# info | debug | warn | error
LOG_LEVEL=info

# ===== Error tracking (optional) =====
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ===== Email (مطلوب لإرسال تأكيد البريد + إشعارات الطلبات والاعتماد) =====
# الطريقة الموصى بها: SMTP فقط (بدون EmailJS). كل الإيميلات تُرسل عبر nodemailer.

# --- SMTP فقط (Gmail أو أي مزود) — لا حاجة لـ EmailJS ---
# Gmail: حساب Google → الأمان → كلمة مرور التطبيق (بعد تفعيل التحقق بخطوتين).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=support@key2lix.com
# SMTP_PASS=your-app-password
# عنوان المرسل (يظهر في "من") — استخدم صندوق الدعم
NOTIFY_FROM=support@key2lix.com

# --- اختياري: EmailJS (يُستخدم فقط إن لم يُضبط SMTP) ---
# EMAILJS_SERVICE_ID=service_xxxxx
# EMAILJS_TEMPLATE_ID=template_xxxxx
# EMAILJS_PUBLIC_KEY=your_public_key
# EMAILJS_PRIVATE_KEY=your_private_key

# رابط الموقع (مطلوب لرابط التأكيد في البريد وتوجيه OAuth)
# BASE_URL=https://key2lix.com

# ===== تسجيل الدخول الاجتماعي (Google / Facebook) =====
# إن لم تُضبط، تبقى أزرار "Google" و "Facebook" تعيد التوجيه وتُظهر رسالة خطأ.
# Google: https://console.cloud.google.com/apis/credentials → إنشاء معرف عميل OAuth 2.0 (ويب)، إضافة URI إعادة التوجيه: https://key2lix.com/api/auth/google/callback
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# Facebook: https://developers.facebook.com/apps → إضافة منتج "Facebook Login" → إعدادات → URI إعادة التوجيه الصحيحة: https://key2lix.com/api/auth/facebook/callback
# FACEBOOK_APP_ID=xxx
# FACEBOOK_APP_SECRET=xxx

# ===== N3: CORS — نطاقات مسموح لها استدعاء API في الإنتاج =====
# عند استضافة الواجهة على نطاق مختلف عن الخادم، أضف النطاقات المسموحة مفصولة بفاصلة.
# مثال: ALLOWED_ORIGINS=https://key2lix.com,https://www.key2lix.com,https://app.key2lix.com
# إذا تركت فارغة فلن يُضاف رأس Access-Control-Allow-Origin (نفس النطاق يعمل بدون CORS).
# ALLOWED_ORIGINS=https://key2lix.com,https://www.key2lix.com

# ===== واتساب (لصفحة كيفية البيع والفوتر) =====
# WHATSAPP_URL=https://wa.me/213XXXXXXXXX

# ===== P29: النسخ الاحتياطي الخارجي (S3 / Backblaze B2) =====
# BACKUP_UPLOAD_ENABLED=1
# BACKUP_S3_BUCKET=your-bucket
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY= أو AWS_ACCESS_KEY_ID
# BACKUP_S3_SECRET_KEY= أو AWS_SECRET_ACCESS_KEY
# B2: BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
# S4: عدد النسخ المحفوظة في السحابة (حذف الأقدم فوق هذا العدد، افتراضي 4)
# BACKUP_CLOUD_KEEP_COUNT=4

# ===== AI (تشات بوت، توليد نصوص، تحليل صور، توصيات) =====
# احصل على المفتاح من https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# ===== بوابة الدفع (Stripe) =====
# STRIPE_SECRET_KEY=sk_test_xxx أو sk_live_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx (للواجهة إن احتجته)
# STRIPE_WEBHOOK_SECRET=whsec_xxx (من Stripe Dashboard → Webhooks)
# Webhook URL: https://key2lix.com/api/payment/webhook
# أحداث: checkout.session.completed

# ===== API للتكامل (ERP / محاسبة) =====
# مفتاح للوصول إلى /api/integration/* بدون جلسة أدمن. راجع docs/API-INTEGRATION.md
# INTEGRATION_API_KEY=your-secure-random-key-here

# ===== P26: روابط وسائل التواصل (للفوتر والـ CTA) =====
# SOCIAL_FACEBOOK_URL=https://facebook.com/YourPage
# SOCIAL_TWITTER_URL=https://twitter.com/YourHandle
# SOCIAL_INSTAGRAM_URL=https://instagram.com/YourHandle
# SOCIAL_YOUTUBE_URL=https://youtube.com/YourChannel
# WHATSAPP_URL أو SOCIAL_WHATSAPP_URL — لزر الواتساب في الفوتر
